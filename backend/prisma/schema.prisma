generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String?  @unique
  phone            String?
  avatar           String?
  googleId         String?  @unique @map("google_id")
  lineId           String?  @unique @map("line_id")
  role             String   @default("customer")
  rating           Float    @default(5.0)
  totalOrders      Int      @default(0) @map("total_orders")
  referralCode     String?  @unique @map("referral_code")
  referralBy       String?  @map("referral_by")
  enterpriseId     String?  @map("enterprise_id")
  subscriptionTier String   @default("free") @map("subscription_tier") // free | pro | enterprise
  createdAt        DateTime @default(now()) @map("created_at")

  enterprise      Enterprise?    @relation(fields: [enterpriseId], references: [id])
  orders          Order[]
  savedAddresses  SavedAddress[]
  ratings         Rating[]
  notifications   Notification[]
  recurringOrders RecurringOrder[]
  disputes        Dispute[]
  subscription    Subscription?

  @@map("users")
}

model Subscription {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  tier         String    // pro | enterprise
  monthlyFee   Int       @map("monthly_fee")
  startedAt    DateTime  @default(now()) @map("started_at")
  renewsAt     DateTime  @map("renews_at")
  cancelledAt  DateTime? @map("cancelled_at")
  vouchersLeft Int       @default(3) @map("vouchers_left") // Pro: 3 express-surcharge-free per month
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

model Driver {
  id         String   @id @default(uuid())
  name       String
  email      String?  @unique
  phone      String?
  googleId   String?  @unique @map("google_id")
  lineId     String?  @unique @map("line_id")
  area       String?
  status     String   @default("offline")
  rating     Float    @default(5.0)
  totalTrips Int      @default(0) @map("total_trips")
  lat        Float    @default(25.0330)
  lng        Float    @default(121.5654)
  createdAt  DateTime @default(now()) @map("created_at")

  orders  Order[]
  ratings Rating[]

  @@map("drivers")
}

model Order {
  id              String    @id
  userId          String    @map("user_id")
  driverId        String?   @map("driver_id")
  enterpriseId    String?   @map("enterprise_id")
  serviceType     String    @default("delivery") @map("service_type")
  status          String    @default("pending")
  pickupAddress   String    @map("pickup_address")
  pickupPhone     String?   @map("pickup_phone")
  deliveryAddress String    @map("delivery_address")
  deliveryPhone   String?   @map("delivery_phone")
  itemContent     String?   @map("item_content")
  itemNote        String?   @map("item_note")
  speedTier       String    @default("standard") @map("speed_tier")
  baseFee         Int       @default(120) @map("base_fee")
  surcharge       Int       @default(0)
  discount        Int       @default(0)
  totalFee        Int       @default(120) @map("total_fee")
  distance        Float     @default(0)
  duration        Int       @default(0)
  scheduledAt     DateTime? @map("scheduled_at")
  rated           Boolean   @default(false)
  recurringId     String?   @map("recurring_id")
  photoUrl        String?   @map("photo_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  driver   Driver?   @relation(fields: [driverId], references: [id])
  ratings  Rating[]
  payment  Payment?
  disputes Dispute[]

  @@map("orders")
}

model Payment {
  id               String    @id @default(uuid())
  orderId          String    @unique @map("order_id")
  amount           Int
  method           String    @default("ecpay")
  status           String    @default("pending")
  merchantTradeNo  String?   @unique @map("merchant_trade_no")
  tradeNo          String?   @map("trade_no")
  paidAt           DateTime? @map("paid_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  target    String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model Rating {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  userId    String?  @map("user_id")
  driverId  String?  @map("driver_id")
  score     Int
  tags      String?
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  order  Order   @relation(fields: [orderId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])
  driver Driver? @relation(fields: [driverId], references: [id])

  @@map("ratings")
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  label     String
  address   String
  type      String   @default("other")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("saved_addresses")
}

model Enterprise {
  id             String   @id @default(uuid())
  name           String
  taxId          String?  @map("tax_id")
  contactName    String?  @map("contact_name")
  contactPhone   String?  @map("contact_phone")
  contactEmail   String?  @map("contact_email")
  billingAddress String?  @map("billing_address")
  monthlyLimit   Int      @default(0) @map("monthly_limit")
  balance        Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  members  User[]
  webhooks WebhookEndpoint[]

  @@map("enterprises")
}

model RecurringOrder {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  serviceType     String    @default("delivery") @map("service_type")
  pickupAddress   String    @map("pickup_address")
  deliveryAddress String    @map("delivery_address")
  itemContent     String?   @map("item_content")
  speedTier       String    @default("standard") @map("speed_tier")
  schedule        String
  active          Boolean   @default(true)
  nextRun         DateTime? @map("next_run")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("recurring_orders")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @default("info")
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model PromoCode {
  id         String   @id @default(uuid())
  code       String   @unique
  discount   Int
  active     Boolean  @default(true)
  usageMax   Int?     @map("usage_max")
  usageCount Int      @default(0) @map("usage_count")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("promo_codes")
}

model Dispute {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  userId      String   @map("user_id")
  reason      String
  description String
  status      String   @default("open")
  resolution  String?
  resolvedBy  String?  @map("resolved_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("disputes")
}

model WebhookEndpoint {
  id           String   @id @default(uuid())
  enterpriseId String   @map("enterprise_id")
  url          String
  secret       String
  events       String   @default("order.status_changed")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  enterprise Enterprise        @relation(fields: [enterpriseId], references: [id])
  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id          String    @id @default(uuid())
  endpointId  String    @map("endpoint_id")
  event       String
  payload     String
  statusCode  Int?      @map("status_code")
  response    String?
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@map("webhook_deliveries")
}

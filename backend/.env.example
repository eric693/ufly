# ── Map services ──────────────────────────────────────────────────────────────
# Mapbox token (server-side: geocoding + directions for fare distance & dispatch).
# Get one at https://account.mapbox.com/access-tokens/ . Leave empty to fall back
# to the free Nominatim+OSRM path (NOT for production — rate-limited).
MAPBOX_TOKEN=

# Optional: Google Distance Matrix (takes priority over Mapbox for fare distance).
GOOGLE_MAPS_API_KEY=

# ── Core (already configured in your real .env) ───────────────────────────────
# DATABASE_URL="postgresql://user:pass@localhost:5432/ufly"
# JWT_SECRET="..."
# PORT=4010
# FRONTEND_URL="https://ufly.crownai.ink"
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET   (OAuth login)
